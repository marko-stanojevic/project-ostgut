NEXT_PUBLIC_API_URL=http://localhost:8080

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Used server-side by Auth.js credentials provider to call the backend
API_URL=http://localhost:8080

# OAuth providers (register at console.developers.google.com / github.com/settings/apps)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# New Relic Browser RUM (optional — agent is disabled when any value is absent)
# Find these values in NR One > Add data > Browser > your app > Application settings
NEXT_PUBLIC_NEW_RELIC_ACCOUNT_ID=
NEXT_PUBLIC_NEW_RELIC_APPLICATION_ID=
NEXT_PUBLIC_NEW_RELIC_LICENSE_KEY=
NEXT_PUBLIC_NEW_RELIC_TRUST_KEY=
NEXT_PUBLIC_NEW_RELIC_AGENT_ID=
