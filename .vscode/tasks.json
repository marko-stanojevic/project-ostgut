{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run build"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Dev Server",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^▲ Next\\.js.*",
          "endsPattern": "^.*(ready|compiled|✓).*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run lint"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Build",
      "type": "shell",
      "command": "go",
      "args": ["build", "-o", "./bin/api", "./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$go"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Test",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "set -a && source .env 2>/dev/null || true && set +a && go test -v -race ./..."],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$go"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Run",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "set -a && source .env && set +a && go run ./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*server starting.*",
          "endsPattern": "^.*(error|exited).*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Format Check",
      "type": "shell",
      "command": "go",
      "args": ["fmt", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Setup: Frontend Dependencies",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm install"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Setup: Backend Dependencies",
      "type": "shell",
      "command": "go",
      "args": ["mod", "download"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$go"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "All: Build All",
      "dependsOn": ["Frontend: Build", "Backend: Build"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "All: Dev (Frontend + Backend)",
      "dependsOn": ["Frontend: Dev Server", "Backend: Run"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
