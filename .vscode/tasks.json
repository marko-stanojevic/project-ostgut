{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run build"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Build (WSL)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "source \"$HOME/.nvm/nvm.sh\"; nvm use 20 >/dev/null; rm -rf .wsl-cache /tmp/project-ostgut/cache/frontend-next; npm run build"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Dev Server",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^▲ Next\\.js.*",
          "endsPattern": "^.*(ready|compiled|✓).*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Dev Server (WSL)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "source \"$HOME/.nvm/nvm.sh\"; nvm use 20 >/dev/null; rm -rf .wsl-cache /tmp/project-ostgut/cache/frontend-next; npm run dev -- --hostname 0.0.0.0"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^▲ Next\\.js.*",
          "endsPattern": "^.*(Ready|compiled|✓).*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "[ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run lint"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NVM_DIR": "${userHome}/.nvm"
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Frontend: Lint (WSL)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "source \"$HOME/.nvm/nvm.sh\"; nvm use 20 >/dev/null; npm run lint"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Build",
      "type": "shell",
      "command": "go",
      "args": ["build", "-o", "./bin/api", "./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "GOARCH": "arm64",
          "GOOS": "linux"
        }
      },
      "problemMatcher": ["$go"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Build (WSL)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "export GOROOT=\"$HOME/.local/go\"; export PATH=\"$GOROOT/bin:$PATH\"; go build -o ./bin/api ./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$go"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Test",
      "type": "shell",
      "command": "sh",
      "args": ["-c", "set -a && source .env.devcontainer 2>/dev/null || true && set +a && go test -v -race ./..."],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$go"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Test (WSL)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "export GOROOT=\"$HOME/.local/go\"; export PATH=\"$GOROOT/bin:$PATH\"; set -a; source \"${workspaceFolder}/backend/.env\"; set +a; go test -v -race ./..."],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$go"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Run (Devcontainer)",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "set -a && source .env.devcontainer && set +a && go run ./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*server starting.*",
          "endsPattern": "^.*(error|exited).*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Run (Local)",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "set -a && source .env && set +a && go run ./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*server starting.*",
          "endsPattern": "^.*(error|exited).*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Run (Local, WSL)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "export GOROOT=\"$HOME/.local/go\"; export PATH=\"$GOROOT/bin:$PATH\"; pkill -x api 2>/dev/null || true; set -a; source \"${workspaceFolder}/backend/.env\"; set +a; go run ./cmd/api"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*database connected.*",
          "endsPattern": "^.*server starting.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Backend: Format Check",
      "type": "shell",
      "command": "go",
      "args": ["fmt", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
