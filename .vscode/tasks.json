    {
      "label": "All: Build All",
      "dependsOn": ["Frontend: Build", "Backend: Build"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "All: Build All (WSL)",
      "dependsOn": ["Frontend: Build (WSL)", "Backend: Build (WSL)"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
