# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace sum (auto-generated, commit go.work but optionally ignore go.work.sum)
go.work.sum

# env file
.env

# Devcontainer-specific backend env
.env.devcontainer

# Editor/IDE
# .idea/
# .vscode/

# Claude Code local settings
.claude/

# OpenTofu / Terraform state and plan files (never commit these)
*.tfstate
*.tfstate.*
*.tfplan
tfplan
.terraform/
.terraform.lock.hcl

# Ignore the API binary generated by Go build
backend/bin/api

# Ignore local PSQL exports
local-export.sql
