PORT=8080
ENV=local
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/ostgut?sslmode=disable

# Independent of frontend AUTH_SECRET. The backend signs/verifies its own JWTs.
JWT_SECRET=your-secret-here

# Base URL returned to clients for media object URLs (blob container public endpoint).
MEDIA_UPLOAD_BASE_URL=https://<storage-account>.blob.core.windows.net/media

# App-level signing secret for upload tokens
MEDIA_UPLOAD_SIGNING_SECRET=your-secret-here

# Azure Blob Storage for server-side media IO (reading back uploads, writing variants).
# Point at the staging storage account to share it with local dev.
#
# Auth priority:
#   1. AZURE_STORAGE_ACCOUNT_KEY set → shared key (simplest for local dev, no RBAC needed)
#   2. Key not set → DefaultAzureCredential: tries env vars, then managed identity
#      (production), then az login (local without a key).
#      AZURE_CLIENT_ID selects which user-assigned managed identity to use on Azure.
#
# To get the account name: az storage account list --resource-group rg-ostgut-staging \
#   --query "[?starts_with(name,'stostgut')].name | [0]" -o tsv
# To get the key:          az storage account keys list --account-name <name> \
#   --resource-group rg-ostgut-staging --query "[0].value" -o tsv
MEDIA_STORAGE_ACCOUNT_NAME=
MEDIA_STORAGE_CONTAINER_NAME=media
AZURE_STORAGE_ACCOUNT_KEY=
